<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for network I/O to the OpenPush backend and image loading. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Android 13+ runtime notification permission. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>

        <!-- OpenPush FCM receiver. Registered by the library so host apps do not
             need to declare it themselves. -->
        <service
            android:name="com.openpush.sdk.messaging.OpenPushFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Trampoline that records the "opened/clicked" event and routes deep
             links before handing control to the host app. -->
        <activity
            android:name="com.openpush.sdk.messaging.NotificationTrampolineActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoDisplay"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <!-- Default notification channel + icon metadata consumed by FCM when
             the app is in the background. Host apps may override these. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="@string/openpush_default_channel_id"
            tools:replace="android:value" />

    </application>
</manifest>
