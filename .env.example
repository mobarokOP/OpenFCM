# =============================================================================
# OpenPush — root environment for the Docker stack
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in secrets before `docker compose up`.
#   cp .env.example .env
# Every variable below is consumed by docker-compose.yml (and passed through to
# the Laravel containers). NEVER commit the real .env.
# =============================================================================

# --- Image / release ---------------------------------------------------------
# Tag applied to the built backend/dashboard images (deploy.yml sets this).
IMAGE_TAG=latest

# --- Application -------------------------------------------------------------
APP_NAME=OpenPush
APP_ENV=production                 # production | local | staging
APP_DEBUG=false                    # NEVER true in production
APP_URL=https://api.openpush.dev
APP_TIMEZONE=UTC                   # contract requires UTC timestamps everywhere
# Generate with: docker compose run --rm app php artisan key:generate --show
APP_KEY=
LOG_CHANNEL=stack
LOG_LEVEL=info                     # debug in local, info/warning in prod

# --- Edge ports (host -> nginx) ----------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443

# --- MySQL 8 -----------------------------------------------------------------
DB_DATABASE=openpush
DB_USERNAME=openpush
DB_PASSWORD=change-me-strong-password
DB_ROOT_PASSWORD=change-me-strong-root-password

# --- Redis 7 (cache + queue + FCM token cache) -------------------------------
REDIS_PASSWORD=change-me-redis-password
# Laravel queue name that push-fan-out jobs land on (API_CONTRACT lifecycle).
REDIS_QUEUE=push
# Workers per queue container. Total = QUEUE_WORKERS * (--scale queue=N).
QUEUE_WORKERS=4

# --- Auth (Dashboard JWT) ----------------------------------------------------
# Long random string used to sign dashboard admin JWTs.
JWT_SECRET=change-me-64-char-random-string
JWT_TTL=1440                       # minutes (24h)

# --- FCM (Firebase Cloud Messaging HTTP v1) ----------------------------------
# NOTE: Per-application Firebase service-account JSON credentials are created in
# the dashboard and stored ENCRYPTED in MySQL (one project per application) —
# they are NOT set here. This is only an optional global default project id used
# by tooling/health checks. Each send resolves the app's own service account and
# caches its OAuth token in Redis.
FCM_DEFAULT_PROJECT_ID=

# --- Mail (transactional: invites, resets, alerts) ---------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@openpush.dev
MAIL_FROM_NAME=OpenPush

# --- Dashboard build ---------------------------------------------------------
# API base baked into the SPA bundle. Relative /v1 works behind the edge proxy;
# set an absolute URL for split-domain deployments.
VITE_API_BASE_URL=/v1
